// ---------------------------------------------------------------------------
// Shaadi Book — Prisma Schema
// Task 1.1: Full data model — users, markets, outcomes, positions,
//           purchases, transactions, admin_audit_log, withdrawal_requests
// ---------------------------------------------------------------------------

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Country {
  US
  IN
}

enum Role {
  GUEST
  ADMIN
}

enum MarketStatus {
  PENDING
  ACTIVE
  PAUSED
  RESOLVED
  VOIDED
}

enum TransactionType {
  DEPOSIT
  PURCHASE
  PAYOUT
  CHARITY_FEE
  WITHDRAWAL
  REFUND
  STRIPE_FEE
  /// Reverse of PURCHASE — money flows from house_amm back to user when selling shares.
  SALE
}

enum AdminAction {
  CREATE_MARKET
  RESOLVE_MARKET
  PAUSE_MARKET
  VOID_MARKET
  VOID_TRADES_AFTER
  APPROVE_WITHDRAWAL
  REJECT_WITHDRAWAL
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum SuggestionStatus {
  PENDING
  APPROVED
  REJECTED
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

/// A registered guest or admin user. Identity is phone-based (OTP via Twilio).
model User {
  id        String   @id @default(uuid())
  name      String
  phone     String   @unique
  country   Country
  role      Role     @default(GUEST)
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  marketsCreated      Market[]            @relation("MarketCreatedBy")
  positions           Position[]
  purchases           Purchase[]
  transactions        Transaction[]
  adminAuditLogs      AdminAuditLog[]     @relation("AdminAuditAdmin")
  withdrawalRequests  WithdrawalRequest[] @relation("WithdrawalUser")
  withdrawalApprovals WithdrawalRequest[] @relation("WithdrawalAdmin")
  marketSuggestions   MarketSuggestion[]  @relation("SuggestionUser")
  marketWatches       MarketWatch[]

  @@map("users")
}

/// A prediction market with 2–5 outcomes (LMSR-priced).
model Market {
  id               String       @id @default(uuid())
  question         String
  status           MarketStatus @default(PENDING)
  createdById      String       @map("created_by")
  openedAt         DateTime?    @map("opened_at")
  scheduledOpenAt  DateTime?    @map("scheduled_open_at")
  /// Admin-overridable b_floor for this market. Null = use B_FLOOR_DEFAULT env var (20).
  /// @deprecated Adaptive b is being replaced by fixed bParameter. Kept to avoid breaking running code.
  bFloorOverride        Decimal?     @map("b_floor_override") @db.Decimal(18, 6)
  /// Maximum shares per outcome for this market (fixed-supply model). Default 1000.
  maxSharesPerOutcome   Int          @default(1000) @map("max_shares_per_outcome")
  /// Fixed b parameter for LMSR pricing. If null, use defaultB(numOutcomes, maxSharesPerOutcome).
  bParameter            Decimal?     @map("b_parameter") @db.Decimal(10, 4)
  createdAt        DateTime     @default(now()) @map("created_at")
  resolvedAt       DateTime?    @map("resolved_at")
  winningOutcomeId String?      @map("winning_outcome_id")
  /// Wedding event this market belongs to (e.g. 'Sangeet', 'Haldi', 'Baraat', 'Wedding Ceremony', 'Reception', 'After Party', 'General')
  eventTag         String?      @map("event_tag")
  /// Which family side this market is relevant to ('Spoorthi', 'Parsh', 'Both')
  familySide       String?      @map("family_side")
  /// Freeform tags like 'dance', 'food', 'emotional'
  customTags       String[]     @default([]) @map("custom_tags")

  // Relations
  createdBy      User            @relation("MarketCreatedBy", fields: [createdById], references: [id])
  outcomes       Outcome[]
  positions      Position[]
  purchases      Purchase[]
  winningOutcome Outcome?        @relation("MarketWinner", fields: [winningOutcomeId], references: [id])
  priceSnapshots PriceSnapshot[]
  watchers       MarketWatch[]

  @@map("markets")
}

/// One possible outcome within a market. Tracks the LMSR state vector q[i] via sharesSold.
model Outcome {
  id         String   @id @default(uuid())
  marketId   String   @map("market_id")
  label      String
  /// 0-based ordering within a market.
  position   Int
  /// The LMSR state vector q[i] — total shares sold for this outcome.
  sharesSold Decimal  @default(0) @map("shares_sold") @db.Decimal(18, 6)
  /// Maximum shares that can be sold for this outcome (fixed-supply cap). Default 1000.
  maxShares  Int      @default(1000) @map("max_shares")
  isWinner   Boolean? @map("is_winner")

  // Relations
  market         Market          @relation(fields: [marketId], references: [id])
  positions      Position[]
  purchases      Purchase[]
  marketWins     Market[]        @relation("MarketWinner")
  priceSnapshots PriceSnapshot[]

  @@map("outcomes")
}

/// A user's aggregated holding of an outcome within a market.
/// This IS mutable (shares and totalCost grow on each purchase).
model Position {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  marketId  String   @map("market_id")
  outcomeId String   @map("outcome_id")
  /// Total shares held (sum of all purchases for this user+market+outcome).
  shares    Decimal  @db.Decimal(18, 6)
  /// Total USD spent (sum of purchase costs).
  totalCost Decimal  @map("total_cost") @db.Decimal(18, 6)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user    User    @relation(fields: [userId], references: [id])
  market  Market  @relation(fields: [marketId], references: [id])
  outcome Outcome @relation(fields: [outcomeId], references: [id])

  /// One position per (user, market, outcome) triple.
  @@unique([userId, marketId, outcomeId])
  @@map("positions")
}

/// An immutable record of a single share purchase. No UPDATE or DELETE — enforced by trigger.
model Purchase {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  marketId    String   @map("market_id")
  outcomeId   String   @map("outcome_id")
  shares      Decimal  @db.Decimal(18, 6)
  cost        Decimal  @db.Decimal(18, 6)
  avgPrice    Decimal  @map("avg_price") @db.Decimal(18, 6)
  priceBefore Decimal  @map("price_before") @db.Decimal(18, 6)
  priceAfter  Decimal  @map("price_after") @db.Decimal(18, 6)
  bAtPurchase Decimal  @map("b_at_purchase") @db.Decimal(18, 6)
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  user    User    @relation(fields: [userId], references: [id])
  market  Market  @relation(fields: [marketId], references: [id])
  outcome Outcome @relation(fields: [outcomeId], references: [id])

  @@map("purchases")
}

/// Append-only double-entry ledger row. No UPDATE or DELETE — enforced by trigger.
/// Every balance change is a row here. User balance = derived SUM, never stored.
model Transaction {
  id              String          @id @default(uuid())
  userId          String          @map("user_id")
  /// Account being debited (e.g. "user:{id}", "house_amm", "charity_pool").
  debitAccount    String          @map("debit_account")
  /// Account being credited.
  creditAccount   String          @map("credit_account")
  type            TransactionType
  /// Amount in USD (stored as Decimal; integer cents at application layer).
  amount          Decimal         @db.Decimal(18, 6)
  /// SHA-256 hash of the previous transaction row (hash chain for tamper detection).
  prevHash        String          @map("prev_hash") @db.Char(64)
  /// SHA-256(prevHash || type || amount || userId || createdAt).
  txHash          String          @map("tx_hash") @db.Char(64)
  stripeSessionId String?         @map("stripe_session_id")
  createdAt       DateTime        @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@map("transactions")
}

/// Immutable log of every admin action for compliance / audit purposes.
/// targetId is a generic UUID pointing to the entity acted upon (market, user, etc.).
model AdminAuditLog {
  id        String      @id @default(uuid())
  adminId   String      @map("admin_id")
  action    AdminAction
  /// UUID of the entity being acted on. Type determined by action field.
  targetId  String      @map("target_id") @db.Uuid
  metadata  Json
  ipAddress String      @map("ip_address")
  createdAt DateTime    @default(now()) @map("created_at")

  // Relations
  admin User @relation("AdminAuditAdmin", fields: [adminId], references: [id])

  @@map("admin_audit_logs")
}

/// Periodic price snapshot for chart history. Stored per-outcome per-market.
/// Snapshots are written after every purchase and by a 60-second background job.
/// Rows older than 48 h are garbage-collected by the cleanup job.
model PriceSnapshot {
  id         String   @id @default(uuid())
  marketId   String   @map("market_id")
  outcomeId  String   @map("outcome_id")
  priceCents Int      @map("price_cents")
  createdAt  DateTime @default(now()) @map("created_at")

  market  Market  @relation(fields: [marketId], references: [id])
  outcome Outcome @relation(fields: [outcomeId], references: [id])

  @@index([marketId, createdAt])
  @@index([outcomeId, createdAt])
  @@map("price_snapshots")
}

/// A guest's request to withdraw their balance via Venmo or Zelle.
model WithdrawalRequest {
  id           String           @id @default(uuid())
  userId       String           @map("user_id")
  amount       Decimal          @db.Decimal(18, 6)
  venmoHandle  String?          @map("venmo_handle")
  zelleContact String?          @map("zelle_contact")
  status       WithdrawalStatus @default(PENDING)
  adminId      String?          @map("admin_id")
  processedAt  DateTime?        @map("processed_at")
  createdAt    DateTime         @default(now()) @map("created_at")

  // Relations
  user  User  @relation("WithdrawalUser", fields: [userId], references: [id])
  admin User? @relation("WithdrawalAdmin", fields: [adminId], references: [id])

  @@map("withdrawal_requests")
}

/// A user's watchlist entry — they want to be notified of activity in this market.
model MarketWatch {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  marketId  String   @map("market_id")
  createdAt DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id])
  market Market @relation(fields: [marketId], references: [id])

  @@unique([userId, marketId])
  @@map("market_watches")
}

/// A guest-submitted suggestion for a new prediction market question.
model MarketSuggestion {
  id           String           @id @default(uuid())
  userId       String           @map("user_id")
  /// The proposed market question text.
  questionText String           @map("question_text")
  /// JSON array of outcome strings (e.g. ["Yes", "No"]).
  outcomes     Json
  /// Optional context or explanation for the suggestion.
  description  String?
  status       SuggestionStatus @default(PENDING)
  /// Admin notes when approving or rejecting.
  adminNotes   String?          @map("admin_notes")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  // Relations
  user User @relation("SuggestionUser", fields: [userId], references: [id])

  @@map("market_suggestions")
}
