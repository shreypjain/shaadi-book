# Copy this file to .env and fill in your values
# cp env.example .env

# Auth
JWT_SECRET=                     # Random 64-char hex
TWILIO_ACCOUNT_SID=             # From Twilio console
TWILIO_AUTH_TOKEN=              # From Twilio console
TWILIO_VERIFY_SERVICE_SID=      # Twilio Verify service for OTP
TWILIO_PHONE_NUMBER=            # For SMS notifications + admin commands

# Payments
STRIPE_SECRET_KEY=              # Stripe account (connected to Shrey's US bank)
STRIPE_WEBHOOK_SECRET=          # Stripe webhook signing secret

# Database
DATABASE_URL=                   # Postgres connection string e.g. postgres://shaadi:password@localhost:5432/shaadi_book
DB_PASSWORD=                    # Postgres password (used in docker-compose)

# Redis
REDIS_URL=                      # Redis connection string e.g. redis://localhost:6379

# App Config
ADMIN_PHONE_NUMBERS=            # Comma-separated: +1XXXXXXXXXX,+91XXXXXXXXXX
B_FLOOR_DEFAULT=20              # Default b_floor for new markets
NODE_ENV=development

# Frontend (public - safe to expose in browser)
NEXT_PUBLIC_WS_URL=             # WebSocket endpoint URL e.g. http://localhost:3001
NEXT_PUBLIC_API_URL=            # Backend API URL e.g. http://localhost:3001
